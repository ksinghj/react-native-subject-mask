{
  "name": "react-native-subject-mask",
  "version": "0.1.0",
  "description": "Apple Vision subject lifting for React Native/Expo — returns an orientation-normalized image, a dim-mask PNG, and the subject outline as an SVG path for JS-driven animation",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "node internal/module_scripts/build.js",
    "clean": "node internal/module_scripts/clean.js",
    "lint": "eslint src/",
    "test": "node internal/module_scripts/test.js",
    "prepare": "node internal/module_scripts/prepare.js",
    "open:ios": "node internal/module_scripts/open-ios.js",
    "open:android": "node internal/module_scripts/open-android.js"
  },
  "keywords": [
    "react-native",
    "expo",
    "ios",
    "vision",
    "visionkit",
    "subject-lift",
    "segmentation",
    "foreground-mask",
    "dim-mask",
    "outline",
    "skia"
  ],
  "repository": "https://github.com/ksinghj/react-native-subject-mask",
  "bugs": {
    "url": "https://github.com/ksinghj/react-native-subject-mask/issues"
  },
  "author": "Kartar Singh Jabanda <kartarsjabanda@gmail.com> (https://github.com/ksinghj)",
  "license": "MIT",
  "homepage": "https://github.com/ksinghj/react-native-subject-mask#readme",
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/jest": "^29.2.1",
    "@types/react": "~19.1.1",
    "babel-preset-expo": "~55.0.8",
    "eslint": "~9.39.4",
    "eslint-config-universe": "^15.0.3",
    "expo": "^57.0.2",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "prettier": "^3.0.0",
    "react-native": "0.82.1",
    "typescript": "^5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "roots": [
      "<rootDir>/src"
    ]
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
